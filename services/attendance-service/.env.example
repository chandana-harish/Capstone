# ── Attendance Service Environment Variables ─────────────────────────────────
NODE_ENV=development
PORT=4004
LOG_LEVEL=info

MONGO_URI=mongodb://attendance-mongo:27017/attendance_db

AUTH_SERVICE_URL=http://auth-service:4001
USER_SERVICE_URL=http://user-service:4002
TRAINING_SERVICE_URL=http://training-service:4003

JWT_SECRET=REPLACE_WITH_SAME_SECRET_AS_AUTH_SERVICE
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:80
