# ── User Service Environment Variables ───────────────────────────────────────
NODE_ENV=development
PORT=4002
LOG_LEVEL=info

MONGO_URI=mongodb://user-mongo:27017/user_db

# URL of the Auth Service for token verification
AUTH_SERVICE_URL=http://auth-service:4001

# Must match the JWT_SECRET in auth-service (used as fallback only)
JWT_SECRET=REPLACE_WITH_SAME_SECRET_AS_AUTH_SERVICE

ALLOWED_ORIGINS=http://localhost:3000,http://frontend:80
